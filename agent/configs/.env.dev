# ========== 应用配置 ==========
APP_NAME=药店智能客服
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ========== 数据库（MySQL） ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=cloud_drugstore

# ========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_EXPIRE_SECONDS=604800

# ========== LLM ==========
# DeepSeek
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ========== 智能体配置 ==========
MAX_HISTORY_MESSAGES=20
TOKEN_LIMIT=4000
SESSION_TIMEOUT_MINUTES=30