<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.clouddrugstore.mapper.DrugSpecificationMapper">
    <update id="update">
        UPDATE drug_specification
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="value != null">
                value = #{value},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="listByDrugId" resultType="com.example.clouddrugstore.entity.DrugSpecification">
        SELECT id, drug_id, name, value
        FROM drug_specification
        WHERE drug_id = #{drugId}
    </select>
    <select id="selectByIds" resultType="com.example.clouddrugstore.entity.DrugSpecification">
        SELECT * FROM drug_specification
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <delete id="deleteByDrugId">
        DELETE FROM drug_specification
        WHERE drug_id = #{drugId}
    </delete>
    <delete id="batchDelete">
        DELETE FROM drug_specification
        WHERE id IN
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>